GORUN_ADDRESS=0.0.0.0:8080
GORUN_SSH_USERNAME=admin
GORUN_SSH_PASSWORD=#####
GORUN_SSH_IDENTITYFILE=~/.ssh/gorun
GORUN_NATS_CONFIG=~/.config/gorun/nats-server.conf

# OTEL enviconment variables https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
# Add any that you need
OTEL_SERICE_NAME=Gorun
OTEL_SDK_DISABLED=false
OTEL_RESOURCE_ATTRIBUTES=""
OTEL_LOG_LEVEL="info"
